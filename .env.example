# GLM API Configuration
# 请在此处填写您的 GLM 4.7 API Key
# 获取方式：访问智谱AI官网 (https://open.bigmodel.cn/) 注册并获取API Key
VITE_GLM_API_KEY=your_glm_api_key_here

# GLM API 端点（通常不需要修改）
VITE_GLM_API_ENDPOINT=https://open.bigmodel.cn/api/paas/v4/chat/completions

# 使用的模型（可选：glm-4, glm-4-flash, glm-4-plus 等）
VITE_GLM_MODEL=glm-4

# 免费生成次数限制
VITE_FREE_GENERATION_LIMIT=3
